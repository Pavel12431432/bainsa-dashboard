# Copy this to .env.local, then `npm run build && npm start`.
# The defaults below run the dashboard against the sample data in `samples/`
# with all Marco/Sofia calls stubbed — no OpenClaw / Docker needed.

# --- Auth ---
# Password you type on the login screen.
DASHBOARD_PASSWORD=bainsa
# Any random string. Stored in the auth cookie; compared on every request.
DASHBOARD_TOKEN=dev-token-change-me
# Set "true" only when serving over HTTPS. Leave blank for localhost.
SECURE_COOKIES=

# --- Data paths (relative to repo root) ---
STORIES_PATH=./samples/stories
MARCO_HANDOFFS_PATH=./samples/handoffs
APPROVALS_PATH=./samples/stories
SOFIA_INSTRUCTIONS_PATH=./samples/instructions

# --- Demo mode ---
# When "true", chatWithAgent() returns canned responses instead of calling
# Docker/OpenClaw. Edit/regenerate/variants all still work end-to-end.
DEMO_MODE=true

# --- Only needed when DEMO_MODE=false (production) ---
# OPENCLAW_PASSWORD=

# --- Instagram publishing (optional) ---
# Long-lived Page access token from Graph API Explorer.
# IG_ACCESS_TOKEN=
# IG Business Account ID (from {pageId}?fields=instagram_business_account).
# IG_USER_ID=
# Public base URL where Meta can fetch story JPEGs. The dashboard saves them
# to a temp dir and serves /ig-temp/<key> from this origin (auto-deleted
# after 10 minutes). Must be reachable from Meta's crawlers.
# IG_PUBLIC_BASE=https://dashboard.example.com
# Optional: override the temp dir (defaults to $TMPDIR/bainsa-ig-temp).
# IG_TEMP_PATH=
